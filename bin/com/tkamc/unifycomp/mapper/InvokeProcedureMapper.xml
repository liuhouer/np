<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tkamc.unifycomp.dao.InvokeProcedureMapper">

	<!-- 查询所有待检查的基金，组合，资产单元，捏合 -->
	<resultMap type="com.tkamc.unifycomp.vo.CompPort" id="BaseResultMap">
		<result column="VC_PORT_CODE" property="portCode" javaType="java.lang.String" jdbcType="VARCHAR"/>
		<result column="VC_PORT_CODE_VALUE" property="portCodeValue" javaType="java.lang.String" jdbcType="VARCHAR"/>
		<result column="VC_PORT_NAME" property="portName" javaType="java.lang.String" jdbcType="VARCHAR"/>
		<result column="C_PORT_TYPE" property="portType" javaType="java.lang.String" jdbcType="VARCHAR"/>
		<result column="CONTROL_TYPE" property="controlType" javaType="java.lang.String" jdbcType="VARCHAR"/>
	</resultMap>
	
	<!-- 查询所有待检查的组合(6个cursor,基金，组合，资产单元，捏合) -->
	<select id="selectCompPort" statementType="CALLABLE" parameterType="java.util.Map">
		{call SP_COMP_PORT(
			#{L_SERIAL_NO, mode=IN, jdbcType=DECIMAL},
			#{L_DATE, mode=IN, jdbcType=DECIMAL},
			#{O_FUND, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_ASSET, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_PORT, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_SPECIAL_FUND, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_SPECIAL_ASSET, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_SPECIAL_PORT, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap}
		)}
	</select>
	
	<!-- 查询所有待检查的组合(新) -->
	<select id="selectCompPortNew" statementType="CALLABLE" parameterType="java.util.Map">
		{call SP_COMP_PORT_NEW(
			#{L_SERIAL_NO, mode=IN, jdbcType=DECIMAL},
			#{L_DATE, mode=IN, jdbcType=DECIMAL},
			#{O_PORT, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap}
		)}
	</select>
	
	<!-- 规则集map -->
	<resultMap id="CompRiskRuleMap" type="com.tkamc.unifycomp.entity.CompRiskRule" >
	    <id column="L_RULE_NO" property="lRuleNo" jdbcType="DECIMAL" />
	    <result column="VC_RULE_CODE" property="vcRuleCode" jdbcType="CHAR" />
	    <result column="VC_RULE_DESCIBE" property="vcRuleDescibe" jdbcType="VARCHAR" />
	    <result column="C_RULE_TYPE" property="cRuleType" jdbcType="CHAR" />
	    <result column="C_LEGAL_TYPE" property="cLegalType" jdbcType="CHAR" />
	    <result column="C_RULE_RANGE" property="cRuleRange" jdbcType="CHAR" />
	    <result column="C_FACT_TYPE" property="cFactType" jdbcType="CHAR" />
	    <result column="VC_NUMERATOR_CODE" property="vcNumeratorCode" jdbcType="CHAR" />
	    <result column="C_NUMERATOR_CNT_TYPE" property="cNumeratorCntType" jdbcType="CHAR" />
	    <result column="VC_NUMERATOR_PARM" property="vcNumeratorParm" jdbcType="VARCHAR" />
	    <result column="VC_DENOMINATOR_CODE" property="vcDenominatorCode" jdbcType="CHAR" />
	    <result column="C_DENOMINATOR_CNT_TYPE" property="cDenominatorCntType" jdbcType="CHAR" />
	    <result column="VC_DENOMINATOR_PARM" property="vcDenominatorParm" jdbcType="VARCHAR" />
	    <result column="VC_GROUP_CODE" property="vcGroupCode" jdbcType="CHAR" />
	    <result column="VC_SUB_RULE_RELATION" property="vcSubRuleRelation" jdbcType="VARCHAR" />
	    <result column="C_COMPARE_TYPE1" property="cCompareType1" jdbcType="CHAR" />
	    <result column="EN_VAL1_UP" property="enVal1Up" jdbcType="DECIMAL" />
	    <result column="EN_VAL1_LOW" property="enVal1Low" jdbcType="DECIMAL" />
	    <result column="C_VIOLATE_TYPE1" property="cViolateType1" jdbcType="CHAR" />
	    <result column="C_COMPARE_TYPE2" property="cCompareType2" jdbcType="CHAR" />
	    <result column="EN_VAL2_UP" property="enVal2Up" jdbcType="DECIMAL" />
	    <result column="EN_VAL2_LOW" property="enVal2Low" jdbcType="DECIMAL" />
	    <result column="C_VIOLATE_TYPE2" property="cViolateType2" jdbcType="CHAR" />
	    <result column="C_COMPARE_TYPE3" property="cCompareType3" jdbcType="CHAR" />
	    <result column="EN_VAL3_UP" property="enVal3Up" jdbcType="DECIMAL" />
	    <result column="EN_VAL3_LOW" property="enVal3Low" jdbcType="DECIMAL" />
	    <result column="C_VIOLATE_TYPE3" property="cViolateType3" jdbcType="CHAR" />
	    <result column="L_ADJUST_LIMIT" property="lAdjustLimit" jdbcType="DECIMAL" />
	    <result column="C_VALID_STATUS" property="cValidStatus" jdbcType="CHAR" />
	    <result column="L_VALID_BEGINDATE" property="lValidBegindate" jdbcType="DECIMAL" />
	    <result column="L_VALID_ENDDATE" property="lValidEnddate" jdbcType="DECIMAL" />
	    <result column="D_CREATE_TIME" property="dCreateTime" jdbcType="DATE" />
	    <result column="D_MODIFY_TIME" property="dModifyTime" jdbcType="DATE" />
	    <result column="VC_CREATE_OPERATOR" property="vcCreateOperator" jdbcType="CHAR" />
	    <result column="VC_MODIFY_OPERATOR" property="vcModifyOperator" jdbcType="CHAR" />
	    <result column="VC_REMARK" property="vcRemark" jdbcType="VARCHAR" />
	    <result column="VC_EXTEND_INFO" property="vcExtendInfo" jdbcType="VARCHAR" />
	</resultMap>
	
	<!-- 公共指标map -->
	<resultMap id="CommonsFactMap" type="com.tkamc.unifycomp.vo.CommonFact" >
	    <result column="VC_DENOMINATOR_CODE" property="vcDenominatorCode" jdbcType="VARCHAR" />
	    <result column="VC_DENOMINATOR_PARM" property="vcDenominatorParm" jdbcType="VARCHAR" />
	    <result column="C_RULE_RANGE" property="cRuleRange" jdbcType="VARCHAR" />
	</resultMap>
	
	<!-- 查询组合相关信息，规则集，公共指标 -->
	<select id="selectCompRules" statementType="CALLABLE" parameterType="java.util.Map">
		{call SP_COMP_RULES(
			#{PORT_CODE, mode=IN, jdbcType=VARCHAR},
			#{PORT_TYPE, mode=IN, jdbcType=VARCHAR},
			#{L_DATE, mode=IN, jdbcType=DECIMAL},
			#{CONTROL_TYPE, mode=IN, jdbcType=VARCHAR},
			#{O_PORT, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.BaseResultMap},
			#{O_RULE, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.CompRiskRuleMap},
			#{O_FILED, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.CommonsFactMap}
		)}
	</select>
	
	<!-- 新股指令导入map -->
	<resultMap id="compStockOrderMap" type="com.tkamc.unifycomp.entity.CompStockOrder" >
	    <result column="L_ORDER_ID" property="lOrderId" jdbcType="DECIMAL" />
	    <result column="VC_STOCK_ID" property="vcStockId" jdbcType="VARCHAR" />
	    <result column="VC_STOCK_NAME" property="vcStockName" jdbcType="VARCHAR" />
	    <result column="L_FUND_ID" property="lFundId" jdbcType="DECIMAL" />
	    <result column="L_PURCHASE_DATE" property="lPurchaseDate" jdbcType="DECIMAL" />
	    <result column="L_VOLUME" property="lVolume" jdbcType="DECIMAL" />
	    <result column="L_PRICE" property="lPrice" jdbcType="DECIMAL" />
	    <result column="L_AMOUNT" property="lAmount" jdbcType="DECIMAL" />
	</resultMap>
	
	<!-- 新股指令导入存储过程 -->
	<select id="selectCompStockOrders" statementType="CALLABLE" parameterType="java.util.Map">
		{call SP_COMP_STOCKORDER(
			#{VC_CODE, mode=IN, jdbcType=VARCHAR},
			#{VC_TYPE, mode=IN, jdbcType=VARCHAR},
			#{O_ORDER, mode=OUT, jdbcType=CURSOR, javaType=java.sql.ResultSet, resultMap=com.tkamc.unifycomp.dao.InvokeProcedureMapper.compStockOrderMap}
		)}
	</select>

</mapper>
